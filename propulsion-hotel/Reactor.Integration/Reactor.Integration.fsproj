<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <WarningLevel>5</WarningLevel>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="SerilogLogFixture.fs" />
        <Compile Include="DynamoConnector.fs" />
        <Compile Include="MessageDbConnector.fs" />
        <Compile Include="ReactorFixture.fs" />
        <Compile Include="ReactorIntegrationTests.fs" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="FsCheck.Xunit.v3" Version="3.3.2" />
        <PackageReference Include="xunit.v3.mtp-v2" Version="3.2.2" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\Reactor\Reactor.fsproj" />
    </ItemGroup>

</Project>
